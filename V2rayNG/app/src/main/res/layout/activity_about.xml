<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: Telegram-канал -->
        <LinearLayout
            android:id="@+id/layout_tg_channel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_telegram_24dp"
                app:tint="@color/md_theme_onSurfaceVariant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_weight="1"
                android:text="@string/about_telegram"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textColor="@color/md_theme_onSurface" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/md_theme_onSurfaceVariant" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginStart="72dp"
            android:layout_marginEnd="20dp"
            android:background="@color/divider_color_light" />

        <!-- Row 2: Проверить обновление -->
        <LinearLayout
            android:id="@+id/layout_check_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_check_update_24dp"
                app:tint="@color/md_theme_onSurfaceVariant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_weight="1"
                android:text="@string/about_check_update"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textColor="@color/md_theme_onSurface" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/md_theme_onSurfaceVariant" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginStart="72dp"
            android:layout_marginEnd="20dp"
            android:background="@color/divider_color_light" />

        <!-- Row 3: Журнал -->
        <LinearLayout
            android:id="@+id/layout_logcat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_logcat_24dp"
                app:tint="@color/md_theme_onSurfaceVariant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_weight="1"
                android:text="@string/about_logcat"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textColor="@color/md_theme_onSurface" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/md_theme_onSurfaceVariant" />
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tv_about_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingBottom="48dp"
            android:textColor="@color/md_theme_outline"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>
